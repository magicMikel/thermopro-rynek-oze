---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = posts.find(p => p.data.featured) ?? posts[0];
const latest = posts.filter(p => p.slug !== featured.slug).slice(0, 8);
---

<BaseLayout title="Rynek OZE – Odnawialne Źródła Energii">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand to-brand-dark text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <p class="text-green-200 text-sm font-semibold uppercase tracking-wider mb-2">Portal ekspercki</p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">
        Pompy ciepła, panele PV,<br class="hidden md:block" /> falowniki i magazyny energii
      </h1>
      <p class="text-green-100 text-lg max-w-xl mb-6">
        Rzetelna wiedza o kosztach, doborze, instalacji i dofinansowaniach OZE. Rankingi sprzętu dla inwestorów i instalatorów.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/ranking/" class="inline-block bg-white text-brand font-bold px-6 py-3 rounded-lg hover:bg-green-50 transition">
          Ranking OZE →
        </a>
        <a href="/posts/" class="inline-block border border-white text-white font-semibold px-6 py-3 rounded-lg hover:bg-white/10 transition">
          Przeglądaj artykuły
        </a>
      </div>
    </div>
  </section>

  <!-- Featured post -->
  <section class="max-w-6xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-800 mb-4 border-l-4 border-brand pl-3">Polecany artykuł</h2>
    <a href={`/posts/${featured.slug}/`} class="group block bg-white rounded-xl shadow hover:shadow-md transition overflow-hidden md:flex">
      <div class="md:w-2/3 p-6">
        {featured.data.category && (
          <span class="text-xs font-semibold text-brand uppercase tracking-wider">{featured.data.category}</span>
        )}
        <h3 class="text-2xl font-bold mt-1 mb-3 group-hover:text-brand transition">{featured.data.title}</h3>
        <p class="text-gray-600 leading-relaxed">{featured.data.excerpt ?? featured.data.description}</p>
        <p class="text-sm text-gray-400 mt-4">{featured.data.date.toLocaleDateString('pl-PL', {day:'numeric', month:'long', year:'numeric'})}</p>
      </div>
    </a>
  </section>

  <!-- Latest posts grid -->
  <section class="max-w-6xl mx-auto px-4 pb-14">
    <h2 class="text-xl font-bold text-gray-800 mb-4 border-l-4 border-brand pl-3">Najnowsze artykuły</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {latest.map(post => (
        <a href={`/posts/${post.slug}/`} class="group bg-white rounded-xl shadow hover:shadow-md transition overflow-hidden flex flex-col">
          <div class="p-5 flex-1">
            {post.data.category && (
              <span class="text-xs font-semibold text-brand uppercase">{post.data.category}</span>
            )}
            <h3 class="font-semibold mt-1 text-gray-800 group-hover:text-brand transition leading-snug">{post.data.title}</h3>
            <p class="text-sm text-gray-500 mt-2 line-clamp-2">{post.data.excerpt ?? post.data.description}</p>
          </div>
          <div class="px-5 pb-4 text-xs text-gray-400">
            {post.data.date.toLocaleDateString('pl-PL', {day:'numeric', month:'short', year:'numeric'})}
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="/posts/" class="inline-block bg-brand text-white font-semibold px-8 py-3 rounded-lg hover:bg-brand-dark transition">
        Wszystkie artykuły
      </a>
    </div>
  </section>

  <!-- Categories shortcut -->
  <section class="max-w-6xl mx-auto px-4 pb-14">
    <h2 class="text-xl font-bold text-gray-800 mb-4 border-l-4 border-brand pl-3">Kategorie OZE</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/ranking/#panele-pv" class="bg-white rounded-xl shadow hover:shadow-md transition p-5 flex items-start gap-3">
        <span class="text-3xl">☀️</span>
        <div>
          <h3 class="font-bold text-gray-800">Panele PV</h3>
          <p class="text-sm text-gray-500 mt-1">Ranking modułów fotowoltaicznych wg sprawności i gwarancji</p>
        </div>
      </a>
      <a href="/ranking/#pompy-ciepla" class="bg-white rounded-xl shadow hover:shadow-md transition p-5 flex items-start gap-3">
        <span class="text-3xl">🌡️</span>
        <div>
          <h3 class="font-bold text-gray-800">Pompy ciepła</h3>
          <p class="text-sm text-gray-500 mt-1">Porównanie SCOP/COP i pracy w niskich temperaturach</p>
        </div>
      </a>
      <a href="/ranking/#falowniki" class="bg-white rounded-xl shadow hover:shadow-md transition p-5 flex items-start gap-3">
        <span class="text-3xl">⚡</span>
        <div>
          <h3 class="font-bold text-gray-800">Falowniki</h3>
          <p class="text-sm text-gray-500 mt-1">Zestawienie falowników wg niezawodności i funkcji</p>
        </div>
      </a>
      <a href="/ranking/#magazyny-energii" class="bg-white rounded-xl shadow hover:shadow-md transition p-5 flex items-start gap-3">
        <span class="text-3xl">🔋</span>
        <div>
          <h3 class="font-bold text-gray-800">Magazyny energii</h3>
          <p class="text-sm text-gray-500 mt-1">Porównanie chemii ogniw, cykli życia i gwarancji</p>
        </div>
      </a>
    </div>
  </section>

</BaseLayout>
